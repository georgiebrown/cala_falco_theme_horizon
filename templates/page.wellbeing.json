            "accordion_row_t7hpVT": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Can I mix and match with the Cala Falcó Collection?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_trbgrh": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Absolutely! Our Cala Falcó Collection is designed to complement each other. You can layer perfumes, or use diffusers and candles together to create a personalised aromatic experience that enhances your mood and ambiance​.</p>",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
