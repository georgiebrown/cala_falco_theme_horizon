    "testimonials_6rfhgc": {
      "type": "testimonials",
      "blocks": {
        "testimonial_JmgVwT": {
          "type": "testimonial",
          "settings": {
            "quote_short": "<p>Cala Falcó at spring is a refined, nuanced non-alcoholic aperitivo, crafted with  passion, exclusivity and remarkable botanical complexity.</p>",
            "cta_label": "Read full testimonial",
            "cta_link": "",
