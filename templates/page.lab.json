              "blocks": {}
            },
            "text_YbjFGi": {
              "type": "text",
              "settings": {
                "text": "<p>Our Scent Scientists are the people that harness the natural botanicals from our Cala Falcó estate and craft them into sensory stories.<br/><br/><strong>Victor Alarcon - Creative Director</strong><br/>With a background in biochemistry and interdisciplinary studies, Victor Alarcón brings a research-driven and creative approach to Cala Falcó as co-founder, creative director, and head of labs. He bridges regenerative agriculture, formulation, and storytelling, leading the creation of natural, high-performance fragrances and sensory systems. Guided by a soil-to-bottle philosophy, his work uses scent to regenerate ecosystems, shape emotion, and redefine contemporary luxury.<br/><br/><strong>Tatsiana Salamanca - Lab Manager</strong><br/>With a PhD in Chemistry and nearly a decade of experience in advanced materials research, Tatsiana brings scientific precision and methodical rigor to Cala Falcó’s laboratory. She oversees the meticulous production of each formula, ensuring<br/>consistency, quality, and fidelity to the original vision.</p>",
                "width": "100%",
                "max_width": "none",
                "alignment": "left",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
                "wrap": "pretty",
                "color": "var(--color-foreground)",
                "background": false,
                "background_color": "#00000026",
                "corner_radius": 0,
                "padding-block-start": 0,
                "padding-block-end": 0,
                "padding-inline-start": 0,
                "padding-inline-end": 0
              },
              "blocks": {}
