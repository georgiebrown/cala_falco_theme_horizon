              "blocks": {
                "text_M4Ht4M": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Everything begins with the soil. We focus on building fertility, increasing organic matter, improving water retention, and supporting the microbial life that sustains the wider ecosystem.</p>",
