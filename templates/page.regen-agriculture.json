            "accordion_row_GNgcd9": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Observation Before Intervention",
                "open_by_default": false,
                "icon": "none",
                "image_upload": "shopify://shop_images/5e5215b8-ebc4-41e2-9090-50e92970e028-removebg-preview.png",
                "width": 38
              },
              "blocks": {
                "text_fXAVkY": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Sun, wind, terrain, water movement and plant behaviour guide our decisions. Rather than imposing rigid solutions, we observe carefully and intervene with precision and restraint. More often than not, nature will find the way.</p>",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
