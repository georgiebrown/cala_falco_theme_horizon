                "width": 26
              },
              "blocks": {
                "text_NF67Bg": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We design for biodiversity from the outset. By combining aromatic, medicinal, pollinator-supporting, and soil-building species, we create a more balanced and resilient system.</p>",
