          "blocks": {
            "text_tU3zyz": {
              "type": "text",
              "name": "t:names.heading",
              "settings": {
                "text": "<p>WATER STEWARDSHIP</p>",
                "width": "fit-content",
                "max_width": "narrow",
                "alignment": "left",
                "type_preset": "h2",
                "font": "var(--font-body--family)",
                "font_size": "1rem",
                "line_height": "normal",
                "letter_spacing": "normal",
                "case": "none",
                "wrap": "pretty",
                "color": "var(--color-foreground)",
