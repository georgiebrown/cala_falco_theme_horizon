              ]
            },
            "accordion_row_UxBVVq": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "How should I store my Cala Falcó Collection products to maintain their quality?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_z36cAi": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>We recommend storing your Cala Falcó Collection products in a cool, dry place away from direct sunlight to preserve the potency of the natural ingredients and extend their shelf life​.</p>",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
