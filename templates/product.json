                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_kEGHRY"
              ]
            },
            "accordion_row_zNFLr7": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "How can I choose the right product for my needs?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_AyGcEE": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Whether you're looking for a calming, invigorating, or balancing effect, our collections are designed with mood programming in mind. Explore our descriptions to find the right combination of scents and ingredients to match your desired experience​.</p>",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
