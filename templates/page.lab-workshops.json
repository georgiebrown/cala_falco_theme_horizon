    "qa_qFEGan": {
      "type": "qa",
      "blocks": {
        "qa_item_JqJnME": {
          "type": "qa_item",
          "settings": {
            "question": "Botanical Drinks Workshop",
            "answer": "<p>Duration: 2–2.5 hours </p><p>Format: Sensorial workshop. Hands-on creation</p><p>Price: From £600 for a group of 4, £120  per additional person<br/><br/>A journey from Mallorca’s sunlit rosemary, mastic and citrus to Scotland’s Scots pine and bog myrtle. Attendees explore hydrolates, aromatic waters from steam distillation, and learn how  to blend their own Botanical Concentrate to later infuse in drinking water.<br/><br/>Guests will: </p><p>• Discover hydrolates & gentle “adaptogenic” aromatics </p><p>• Explore a curated Mediterranean + Scottish hydrolate library </p><p>• Create a personal 30 ml concentrate </p><p>• Practise a smell sip → breathe → ritual</p>",
            "image_upload": "shopify://shop_images/af0fa225-1a07-4161-9ff4-b1daf7fb01b4-removebg-preview.png",
            "open_by_default": true
          }
        },
        "qa_item_UWFm9N": {
          "type": "qa_item",
          "settings": {
            "question": "Olfactory Tasting",
            "answer": "<p>Exploring England’s landscapes through scent</p><p><br/></p><p>Duration: 1 hour</p><p>Format: Guided fragrance tasting</p><p>Price: From £600 for a group of 4, £120 per additional person<br/><br/></p><p><br/></p><p>An elegant olfactory tasting exploring England’s landscapes through scent, The Garden, The Seaside, The Countryside, Wild Nature.</p><p></p><p>A refined exercise in emotional memory, slow perception and sensory presence.</p>",
            "image_upload": "shopify://shop_images/Vector_31.png",
            "open_by_default": false
          }
        },
        "qa_item_CUyNLe": {
          "type": "qa_item",
          "settings": {
            "question": "The Anatomy of Calm",
            "answer": "<p>Create Your Functional Synergy Perfume<br/><br/></p><p>Duration: 2 hours</p><p>Format: Neuroaesthetic ritual + creation lab</p><p>Price: From £250 per person, minimum group of 10 <br/><br/></p><p>A theatrical meditation on calm.</p><p>Attendees learn how certain botanical molecules modulate the nervous system through breath, movement, and sound.</p><p>They then create a Fragrance of Equilibrium, a personalised roll-on synergy for daily ritual.</p>",
            "image_upload": "shopify://shop_images/Vector_29.png",
            "open_by_default": false
          }
        },
        "qa_item_bnDiWr": {
          "type": "qa_item",
          "settings": {
            "question": "Create Your Own Perfume",
            "answer": "<p>Bespoke perfume creation in the Perfumery Lab</p><p><br/></p><p>Duration: 2–4 hours</p><p>Format: Bespoke perfume building</p><p>Price: From £600 for a group of 4, £120 per additional person<br/><br/>A deep dive into raw ingredients, distillation principles, accords, and personal formula building.</p><p>Guests create a bespoke 11 ml perfume guided by one of our perfumers.</p>",
            "image_upload": "shopify://shop_images/Vector_28.png",
            "open_by_default": false
          }
        },
        "qa_item_4re7Ty": {
          "type": "qa_item",
          "settings": {
            "question": "Cala Falcó at Spring Tasting",
            "answer": "<p>Discover the botanical notes in our first botanical Aperitivo</p><p><br/></p><p>Duration: 30–45 minutes </p><p>Format: Guided tastings from the Cala Falco at Spring natural botanical Aperitivo</p><p>Price: From £600 for a group of 4, £120 per additional person</p><p><br/></p><p>A sensorial tasting of Spring, our botanical Aperitivo crafted with wild Mediterranean plants and UK grown botanicals.</p><p>Perfect as an add-on for Dry January or wellness evenings.</p>",
            "image_upload": "shopify://shop_images/af0fa225-1a07-4161-9ff4-b1daf7fb01b4-2-removebg-preview.png",
            "open_by_default": false
          }
        }
