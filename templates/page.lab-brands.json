            "text_P8dhNc": {
              "type": "text",
              "name": "t:names.text",
              "settings": {
                "text": "<p>SO FONG is a schooner built in 1937 by the AH KING shipyard in Causeway Bay, Hong Kong. Commissioned by a Stockbroker for the purpose of circumnavigating the world with his son. </p><p>Since then she has raced, sailed the world, worked as a diving and salvage vessel and even acted as a spy ship before being captured by the Vietnamese militia. </p><p>Today, So Fong sails the waters of the Balearic Islands. It is here that we were commissioned to translate her incredible travels and tell the olfactory story through scent science for her owner. Following a deep dive into the history of her journeys we created a bespoke fragrance to that reflected her aromatic voyage and story, building a beautifully rich and complex fragrance.</p>",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
                "type_preset": "rte",
                "font": "var(--font-body--family)",
