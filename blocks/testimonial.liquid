{%- liquid
  assign block_settings = block.settings
  assign block_index = section.blocks | find_index: 'id', block.id
-%}

{%- capture card_content -%}
  <article class="testimonials-card" aria-label="{% if block_settings.author != blank %}Testimonial by {{ block_settings.author | escape }}{% else %}Testimonial{% endif %}">
    <div class="testimonials-card__quote">
      <div class="testimonials-card__quote-mark" aria-hidden="true">
        &ldquo;
      </div>

      {% if block_settings.quote_short != blank %}
        <div class="testimonials-card__quote-short rte">
          {{ block_settings.quote_short }}
        </div>
      {% endif %}

      {% if block_settings.quote_full != blank %}
        <show-more-component
          class="testimonials-card__show-more show-more"
          data-expanded="false"
        >
          <button
            class="show-more__button button-unstyled button-unstyled--with-icon"
            type="button"
            ref="showMoreButton"
            on:click="/toggle"
            aria-expanded="false"
            aria-controls="Testimonials-{{ section.id }}-{{ block.id }}-quote-more"
          >
            <span class="svg-wrapper icon-plus">
              {{- 'icon-plus.svg' | inline_asset_content -}}
            </span>

            <span class="show-more__label show-more__label--more">
              {{ 'actions.show_more' | t }}
            </span>
            <span class="show-more__label show-more__label--less">
              {{ 'actions.show_less' | t }}
            </span>
          </button>

          <div
            id="Testimonials-{{ section.id }}-{{ block.id }}-quote-more"
            ref="showMoreContent"
            class="testimonials-card__expand-content"
          >
            <div
              ref="showMoreItems[]"
              class="hidden testimonials-card__quote-full rte"
            >
              {{ block_settings.quote_full }}
            </div>
          </div>
        </show-more-component>
      {% endif %}

      {% if block_settings.author != blank or block_settings.author_title != blank %}
        <div class="testimonials-card__author">
          {% if block_settings.author != blank %}
            <span class="testimonials-card__author-name">{{ block_settings.author }}</span>
          {% endif %}
          {% if block_settings.author_title != blank %}
            <span class="testimonials-card__author-title">{{ block_settings.author_title }}</span>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="testimonials-card__media" aria-hidden="false">
      {% if block_settings.image != blank %}
        {{
          block_settings.image
          | image_url: width: 2000
          | image_tag:
            widths: '750, 1100, 1500, 2000',
            sizes: '100vw',
            class: 'testimonials-card__image',
            loading: 'lazy',
            alt: (block_settings.image.alt | default: block_settings.author | default: 'Testimonial image')
        }}
      {% endif %}
    </div>
  </article>
{%- endcapture -%}

{%- render 'slideshow-slide',
  index: block_index,
  slide_id: block.id,
  class: 'testimonials-card__slide',
  attributes: block.shopify_attributes,
  children: card_content,
  slide_size: section.settings.slide_height,
  navigate_to_slide: false
-%}

{% schema %}
{
  "name": "Testimonial",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "richtext",
      "id": "quote_short",
      "label": "Quote (short)"
    },
    {
      "type": "richtext",
      "id": "quote_full",
      "label": "Quote (full, expands)"
    },
    {
      "type": "text",
      "id": "author",
      "label": "Author"
    },
    {
      "type": "text",
      "id": "author_title",
      "label": "Author title"
    }
  ],
  "presets": [
    {
      "name": "Testimonial"
    }
  ]
}
{% endschema %}
