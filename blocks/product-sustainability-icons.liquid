{%- liquid
  assign block_settings = block.settings
  assign items = closest.product.metafields.custom.sustainability_icons.value
  assign has_renderable = false

  if items != blank
    for item in items
      assign item_title = item.title.value | default: item.title | strip
      assign icon_asset = item.icon.value | default: item.icon
      if item_title != blank and icon_asset != blank
        assign has_renderable = true
        break
      endif
    endfor
  endif

  assign show_editor_placeholder = false
  if request.design_mode or request.visual_preview_mode
    unless has_renderable
      assign show_editor_placeholder = true
    endunless
  endif
-%}

{% if has_renderable %}
  <div
    class="product-sustainability-icons spacing-style"
    style="{% render 'spacing-style', settings: block_settings %}"
    {{ block.shopify_attributes }}
  >
    <ul
      class="product-sustainability-icons__list"
      role="list"
      aria-label="{{ 'accessibility.sustainability_icons' | t }}"
    >
      {%- for item in items -%}
        {%- liquid
          assign item_title = item.title.value | default: item.title | strip
          assign icon_asset = item.icon.value | default: item.icon
          assign item_title_escaped = item_title | escape
        -%}
        {%- if item_title != blank and icon_asset != blank -%}
          <li class="product-sustainability-icons__item">
            <div class="product-sustainability-icons__circle">
              {{
                icon_asset
                | image_url: width: 160
                | image_tag:
                  alt: item_title_escaped,
                  class: 'product-sustainability-icons__image',
                  loading: 'lazy',
                  widths: '80, 120, 160',
                  sizes: '(min-width: 750px) 5rem, 4rem'
              }}
            </div>
            <p class="product-sustainability-icons__label">{{ item_title | escape }}</p>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>
{% elsif show_editor_placeholder %}
  <div
    class="product-sustainability-icons product-sustainability-icons--editor-placeholder spacing-style"
    style="{% render 'spacing-style', settings: block_settings %}"
    role="region"
    aria-labelledby="SustainabilityIconsEditorHint-{{ block.id }}"
    {{ block.shopify_attributes }}
  >
    <p
      class="product-sustainability-icons__editor-hint"
      id="SustainabilityIconsEditorHint-{{ block.id }}"
    >
      {{ 'content.sustainability_icons_editor_hint' | t }}
    </p>
    <ul
      class="product-sustainability-icons__list"
      aria-hidden="true"
    >
      <li class="product-sustainability-icons__item">
        <div class="product-sustainability-icons__circle product-sustainability-icons__circle--placeholder">
          <span class="svg-wrapper product-sustainability-icons__placeholder-icon" aria-hidden="true">
            {{- 'icon-info.svg' | inline_asset_content -}}
          </span>
        </div>
        <p class="product-sustainability-icons__label product-sustainability-icons__label--muted">
          {{ 'content.sustainability_icons_preview_1' | t }}
        </p>
      </li>
      <li class="product-sustainability-icons__item">
        <div class="product-sustainability-icons__circle product-sustainability-icons__circle--placeholder">
          <span class="svg-wrapper product-sustainability-icons__placeholder-icon" aria-hidden="true">
            {{- 'icon-info.svg' | inline_asset_content -}}
          </span>
        </div>
        <p class="product-sustainability-icons__label product-sustainability-icons__label--muted">
          {{ 'content.sustainability_icons_preview_2' | t }}
        </p>
      </li>
      <li class="product-sustainability-icons__item">
        <div class="product-sustainability-icons__circle product-sustainability-icons__circle--placeholder">
          <span class="svg-wrapper product-sustainability-icons__placeholder-icon" aria-hidden="true">
            {{- 'icon-info.svg' | inline_asset_content -}}
          </span>
        </div>
        <p class="product-sustainability-icons__label product-sustainability-icons__label--muted">
          {{ 'content.sustainability_icons_preview_3' | t }}
        </p>
      </li>
      <li class="product-sustainability-icons__item">
        <div class="product-sustainability-icons__circle product-sustainability-icons__circle--placeholder">
          <span class="svg-wrapper product-sustainability-icons__placeholder-icon" aria-hidden="true">
            {{- 'icon-info.svg' | inline_asset_content -}}
          </span>
        </div>
        <p class="product-sustainability-icons__label product-sustainability-icons__label--muted">
          {{ 'content.sustainability_icons_preview_4' | t }}
        </p>
      </li>
    </ul>
  </div>
{% endif %}

{% stylesheet %}
  .product-sustainability-icons__list {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 1rem 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .product-sustainability-icons__list {
      flex-wrap: nowrap;
      gap: 1.5rem;
    }
  }

  .product-sustainability-icons__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1 1 40%;
    min-width: 0;
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    .product-sustainability-icons__item {
      flex: 1 1 0;
    }
  }

  .product-sustainability-icons__circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    margin-block-end: 0.5rem;
  }

  @media screen and (min-width: 750px) {
    .product-sustainability-icons__circle {
      width: 5rem;
      height: 5rem;
    }
  }

  .product-sustainability-icons__image {
    object-fit: contain;
  }

  .product-sustainability-icons__label {
    margin: 0;
    max-width: 11rem;
    line-height: var(--font-paragraph--line-height);
    color: rgb(var(--color-foreground-rgb));
  }

  .product-sustainability-icons__editor-hint {
    margin: 0 0 0.75rem;
    font-size: min(0.8125rem, var(--font-paragraph--size));
    line-height: var(--font-paragraph--line-height);
    color: rgb(var(--color-foreground-rgb) / 0.65);
    text-align: center;
  }

  .product-sustainability-icons--editor-placeholder .product-sustainability-icons__list {
    opacity: 0.72;
  }

  .product-sustainability-icons__circle--placeholder {
    border: 1px dashed rgb(var(--color-foreground-rgb) / 0.22);
    background-color: rgb(var(--color-foreground-rgb) / 0.04);
  }

  .product-sustainability-icons__placeholder-icon {
    display: flex;
    width: 40%;
    height: 40%;
    color: rgb(var(--color-foreground-rgb) / 0.35);
  }

  .product-sustainability-icons__placeholder-icon svg {
    width: 100%;
    height: 100%;
  }

  .product-sustainability-icons__label--muted {
    color: rgb(var(--color-foreground-rgb) / 0.55);
  }
{% endstylesheet %}

