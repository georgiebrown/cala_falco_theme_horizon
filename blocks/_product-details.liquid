{%- assign block_settings = block.settings -%}
{%- liquid
  assign featured_collection = closest.product.collections.first
-%}
<div
  id="ProductInformation-{{ section.id }}"
  class="
    product-details
    {% if request.page_type == 'product' or block_settings.sticky_details_desktop %} sticky-content--desktop{% endif %}
    {% if block_settings.height == 'fill' -%} full-height--desktop{% endif -%}
  "
  style="--details-position: {{ block_settings.details_position }};"
  data-testid="product-information-details"
  {% if settings.transition_to_main_product %}
    data-view-transition-type="product-details"
  {% endif %}
>
    <div class="product-details__meta spacing-style">
      <nav class="product-details__breadcrumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span aria-hidden="true">/</span>
        <a href="{{ routes.all_products_collection_url }}">Shop</a>
        {% if featured_collection %}
          <span aria-hidden="true">/</span>
          <a href="{{ featured_collection.url }}">{{ featured_collection.title }}</a>
        {% endif %}
      </nav>
      <div class="product-details__collection-row">
        {% if featured_collection %}
          <p class="product-details__collection-title h6">
            {{ featured_collection.title }}
          </p>
        {% endif %}
        <button
          type="button"
          class="button button-unstyled product-details__share"
          data-share-product
          data-share-url="{{ shop.url }}{{ closest.product.url }}"
          data-share-title="{{ closest.product.title | escape }}"
          aria-label="Share product"
        >
          <span class="product-details__share-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 11.25V2.25M9 2.25L5.625 5.625M9 2.25L12.375 5.625M3 9.75V13.5C3 14.7426 4.00736 15.75 5.25 15.75H12.75C13.9926 15.75 15 14.7426 15 13.5V9.75" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span>Share</span>
        </button>
      </div>
    </div>

  {% capture children %}
    <div class="view-product-title">
      <a
        href="{{ closest.product.selected_or_first_available_variant.url }}"
        class="link"
      >
        {{- closest.product.title }}
      </a>
    </div>
    {% content_for 'blocks' %}
  {% endcapture %}

  {% render 'group', children: children, settings: block_settings, shopify_attributes: block.shopify_attributes %}
</div>

<script>
  (() => {
    const shareButtons = document.querySelectorAll('[data-share-product]');
    if (!shareButtons.length) return;

    shareButtons.forEach((shareButton) => {
      shareButton.addEventListener('click', async () => {
        const shareUrl = shareButton.getAttribute('data-share-url') || window.location.href;
        const shareTitle = shareButton.getAttribute('data-share-title') || document.title;

        if (navigator.share) {
          try {
            await navigator.share({ title: shareTitle, url: shareUrl });
            return;
          } catch (_error) {
            // Fall through to clipboard copy if share dialog was cancelled or failed.
          }
        }

        try {
          await navigator.clipboard.writeText(shareUrl);
          shareButton.classList.add('product-details__share--copied');
          setTimeout(() => shareButton.classList.remove('product-details__share--copied'), 1400);
        } catch (_error) {
          window.prompt('Copy this link:', shareUrl);
        }
      });
    });
  })();
</script>

{% stylesheet %}
  /* Clear padding on mobile, if not full-width */
  @media screen and (max-width: 749px) {
    .product-information.section--page-width .product-details > .group-block {
      padding-inline: 0;
    }
  }

  .view-product-title {
    display: none;
  }

  .product-details {
    align-self: start;
    justify-content: center;
  }

  .product-details__meta {
    padding-top: 24px;
  }

  .product-details__breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: var(--padding-sm);
    font-size: 0.95rem;
  }

  .product-details__breadcrumbs a {
    text-decoration: none;
    color: inherit;
  }

  .product-details__collection-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-md);
  }



  .product-details__share {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.95rem;
  }

  .product-details__share-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .product-details__share--copied span:last-child::after {
    content: ' copied';
    font-size: 0.85em;
    opacity: 0.8;
  }


  @media screen and (min-width: 750px) {
    .product-details {
      align-self: start;
    }

    .product-details > .group-block {
      height: min-content;
    }

    .full-height--desktop {
      height: 100%;
      max-height: calc(100vh - var(--header-group-height, 0));
      min-height: fit-content;
    }

    .full-height--desktop .group-block {
      align-self: var(--details-position, 'flex-start');
    }
  }
{% endstylesheet %}

