{% liquid
  assign link_source = block.settings.link_source | default: 'policies'
  assign has_links = false

  if link_source == 'menu' and block.settings.custom_menu != blank
    assign has_links = true
  elsif link_source == 'policies' and shop.policies.size > 0
    assign has_links = true
  endif
%}

{% if has_links %}
  <ul
    class="
      policy_list list-unstyled
      custom-typography
      {% if block.settings.font_size != '' %}custom-font-size{% endif %}
    "
    style="{% render 'typography-style', preset: 'custom', settings: block.settings %}"
    {{ block.shopify_attributes }}
  >
    {% if link_source == 'menu' and block.settings.custom_menu != blank %}
      {%- for link in block.settings.custom_menu.links -%}
        {%- if link != blank -%}
          <li>
            <a
              href="{{ link.url }}"
              class="footer-utilities__text"
            >
              {{- link.title | escape -}}
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    {% else %}
      {%- for policy in shop.policies -%}
        {%- if policy != blank -%}
          <li>
            <a
              href="{{ policy.url }}"
              class="footer-utilities__text"
            >
              {{- policy.title | escape -}}
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    {% endif %}
  </ul>
{% endif %}

{% stylesheet %}
  .policy_list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin: 0;
    padding: 0;
  }

  .policy_list li {
    margin: 0;
    padding: 0;
  }

  .policy_list a {
    color: var(--color-foreground);
    display: inline-block;
    text-align: start;
    outline-color: #0000;
    font-size: var(--font-size, 0.75rem);
    text-transform: var(--text-transform, none);
    text-decoration: none;
  }

  .policy_list a:hover {
    text-decoration: underline;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.policy_list",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.manage_policies"
    },
    {
      "type": "select",
      "id": "link_source",
      "label": "Link source",
      "options": [
        {
          "value": "policies",
          "label": "Policies"
        },
        {
          "value": "menu",
          "label": "Menu"
        }
      ],
      "default": "policies"
    },
    {
      "type": "link_list",
      "id": "custom_menu",
      "label": "Menu",
      "visible_if": "{{ block.settings.link_source == 'menu' }}"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "t:settings.size",
      "options": [
        {
          "value": "0.625rem",
          "label": "10px"
        },
        {
          "value": "0.75rem",
          "label": "12px"
        },
        {
          "value": "0.875rem",
          "label": "14px"
        },
        {
          "value": "1rem",
          "label": "16px"
        },
        {
          "value": "1.125rem",
          "label": "18px"
        }
      ],
      "default": "0.75rem"
    },
    {
      "type": "select",
      "id": "case",
      "label": "t:settings.case",
      "options": [
        {
          "value": "none",
          "label": "t:options.default"
        },
        {
          "value": "uppercase",
          "label": "t:options.uppercase"
        }
      ],
      "default": "none"
    }
  ],
  "presets": [
    {
      "name": "t:names.policy_list",
      "category": "t:categories.footer"
    }
  ]
}
{% endschema %}
