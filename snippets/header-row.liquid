{% doc %}
  Renders a responsive header row with three columns (left, center, right).
  Organizes header elements based on their configured position and row placement

  @param {string} row - The row identifier ('top' or 'bottom')
  @param {string} order - Comma-separated list of item names defining the order of elements
  @param {object} settings - Section settings object containing position and row settings for each item
  @param {string} [first] - Optional captured HTML for the first item (typically drawer menu for top row)
  @param {string} [logo] - Captured HTML for the logo element
  @param {string} [menu] - Captured HTML for the menu navigation
  @param {string} [menu_left] - Captured HTML for left half of split menu
  @param {string} [menu_right] - Captured HTML for right half of split menu
  @param {string} [actions] - Captured HTML for header actions (cart, account buttons, etc.)
  @param {string} [localization] - Captured HTML for language/country selector
  @param {string} [search] - Captured HTML for search input
  @param {string} [drawer_search] - Captured HTML for drawer-based search
{% enddoc %}

{%- liquid
  assign order = order | split: ','
  assign left = ''
  assign center = ''
  assign right = ''
  assign split_menu_enabled = false

  if settings.logo_position == 'center' and settings.menu_position == 'split'
    assign split_menu_enabled = true
  endif

  if first != blank
    assign left = 'first '
  endif

  for item in order
    assign column_key = item | append: '_position'
    assign row_key = item | append: '_row'
    assign item_row = settings[row_key] | default: 'top'
    assign item_column = settings[column_key] | default: 'left'

    case item
      when 'actions'
        assign item_column = 'right'
    endcase

    if item_row == row
      if item == 'menu' and split_menu_enabled
        assign left = left | append: 'menu_left '
        assign right = right | append: 'menu_right '
        continue
      endif

      if item_column == 'split'
        assign item_column = 'center'
      endif

      case item_column
        when 'left'
          assign left = left | append: item | append: ' '
        when 'center'
          assign center = center | append: item | append: ' '
        else
          assign right = right | append: item | append: ' '
      endcase
    endif
  endfor

  assign columns = 'left,center,right' | split: ','
-%}

{%- for column in columns -%}
  {%- capture items_for_column -%}
    {% case column %}
      {% when 'left' %}
        {{ left }}
      {% when 'center' %}
        {{ center }}
      {% else %}
        {{ right }}
    {% endcase %}
  {%- endcapture -%}

  {%- assign items_array = items_for_column | strip | split: ' ' | compact -%}

  {%- if items_array.size > 0 -%}
    <div
      class="header__column header__column--{{ column }}"
      data-testid="header-{{ row }}-{{ column }}"
    >
      {%- assign render_grouped_utilities = false -%}
      {%- if column == 'right' and split_menu_enabled and settings.logo_position == 'center' -%}
        {%- assign render_grouped_utilities = true -%}
      {%- endif -%}

      {%- capture grouped_utilities_markup -%}{%- endcapture -%}
      {% for key in items_array %}
        {% unless key == blank %}
          {% if render_grouped_utilities and key == 'search' %}
            {% capture grouped_utilities_markup %}
              {{ grouped_utilities_markup }}
              {{ search }}
            {% endcapture %}
            {% continue %}
          {% endif %}
          {% if render_grouped_utilities and key == 'actions' %}
            {% capture grouped_utilities_markup %}
              {{ grouped_utilities_markup }}
              {{ actions }}
            {% endcapture %}
            {% continue %}
          {% endif %}
          {% case key %}
            {% when 'first' %}
              {{ first }}
            {% when 'logo' %}
              {{ logo }}
            {% when 'menu' %}
              {{ menu }}
            {% when 'menu_left' %}
              {{ menu_left }}
            {% when 'menu_right' %}
              {{ menu_right }}
            {% when 'localization' %}
              {{ localization }}
            {% when 'search' %}
              {{ search }}
            {% when 'drawer_search' %}
              {{ drawer_search }}
            {% when 'actions' %}
              {{ actions }}
          {% endcase %}
        {% endunless %}
      {% endfor %}

      {% if render_grouped_utilities and grouped_utilities_markup != blank %}
        <div class="header__utilities-group">
          {{ grouped_utilities_markup }}
        </div>
      {% endif %}
    </div>
  {%- endif -%}
{%- endfor -%}
