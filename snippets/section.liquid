{%- doc -%}
  Renders a wrapper section

  @param {section} section - The section object
  @param {string} children - The children of the section
{%- enddoc -%}

<div class="section-background{% if section.settings.section_width == 'page-width' %} section-background--page-white{% else %} color-{{ section.settings.color_scheme }}{% endif %}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}{% if section.settings.section_width == 'page-width' %} section--page-shell-white{% endif %}"
  data-testid="ui-test-section"

  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}

  style="
    {% if section.settings.section_height == 'custom' %}
      --section-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --section-min-height: 100svh;
    {% elsif section.settings.section_height != '' %}
      --section-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}

    {% if section.settings.section_height != '' %}
     --section-preview-height: 600px;
     {% endif %}
  "
>
  <div class="custom-section-background">
    {% render 'background-media',
      background_media: section.settings.background_media,
      background_video: section.settings.video,
      background_video_position: section.settings.video_position,
      background_image: section.settings.background_image,
      background_image_position: section.settings.background_image_position
    %}
  </div>

  <div
    class="border-style custom-section-content{% if section.settings.show_inner_frame %} custom-section-content--inner-frame{% endif %}{% if section.settings.show_image_border %} custom-section-content--image-inner-frame custom-section-content--image-border-{{ section.settings.image_border_position | default: 'inside' }}{% endif %}"
    style="
      {% render 'border-override', settings: section.settings %}
      {% if section.settings.show_inner_frame %}
        --inner-frame-inset: {{ section.settings.inner_frame_inset }}px;
        --inner-frame-radius: {{ section.settings.inner_frame_radius }}px;
      {% endif %}
      {% if section.settings.show_image_border %}
        --image-inner-frame-color: {{ section.settings.image_border_color }};
      {% endif %}
    "
  >
    {% if section.settings.toggle_overlay %}
      {% render 'overlay', settings: section.settings, layer: '0' %}
    {% endif %}

    {% if section.settings.show_intro %}
      {% if section.settings.intro_heading != blank or section.settings.intro_description != blank %}
        <div class="custom-section__intro spacing-style">
          {% if section.settings.intro_heading != blank %}
            <h2 class="custom-section__intro-heading">{{ section.settings.intro_heading }}</h2>
          {% endif %}
          {% if section.settings.intro_description != blank %}
            <div class="custom-section__intro-description rte">
              {{ section.settings.intro_description }}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

    <div
      class="
        spacing-style
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        section-content-wrapper
        {% if section.settings.vertical_on_mobile %} mobile-column{% endif %}
      "
      style="
        {% render 'layout-panel-style', settings: section.settings %}
        {% render 'spacing-style', settings: section.settings %}
        {% if section.settings.show_inner_frame %}
          --padding-block-start: var(--inner-frame-inset, 12px);
          --padding-block-end: var(--inner-frame-inset, 12px);
          --padding-inline-start: var(--inner-frame-inset, 12px);
          --padding-inline-end: var(--inner-frame-inset, 12px);
        {% endif %}
      "
      data-testid="section-content"
    >
      {{ children }}
    </div>
  </div>
</div>

{% stylesheet %}
  .section-wrapper {
    --section-height-offset: 0px;
  }

  .section[data-shopify-visual-preview] {
    min-height: var(--section-preview-height);
    padding-top: 0;
  }

  .section[data-shopify-visual-preview] .custom-section-background {
    display: none;
  }

  body:has(> #header-group > .header-section > #header-component[transparent]):not(
      :has(> #header-group > .header-section + .shopify-section)
    )
    > main
    > .section-wrapper:first-child {
    --section-height-offset: var(--header-group-height, 0);
  }

  .custom-section-background {
    grid-column: 1 / -1;
  }

  .section-background--page-white,
  .section--page-shell-white {
    background: #fff;
  }

  .custom-section-content {
    z-index: var(--layer-flat);
  }

  .section--page-shell-white .custom-section-content {
    background: transparent;
  }

  .section--page-shell-white .custom-section-content--image-inner-frame {
    background: rgb(var(--color-background-rgb));
  }

  .section.section--page-width .custom-section-content {
    padding-inline: var(--page-margin);
  }

  .section.section--small > * {
    grid-column: 2;
  }

  .section.section--small .custom-section-content {
    width: min(100%, calc(var(--page-content-width) * 0.8));
    margin-inline: auto;
  }

  .custom-section-content--inner-frame {
    position: relative;
    padding: var(--inner-frame-inset, 12px);
  }

  .custom-section-content--inner-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid #F4C077;
    border-radius: var(--inner-frame-radius, 12px);
    pointer-events: none;
    z-index: 0;
  }

  .custom-section-content--inner-frame > * {
    position: relative;
    z-index: 1;
  }

  .custom-section-content--image-inner-frame .image-block {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-sizing: border-box;
  }

  .custom-section-content--image-inner-frame .image-block__image,
  .custom-section-content--image-inner-frame .placeholder-image {
    --border-style: none;
    --border-width: 0px;
    --border-radius: 16px;
    border-radius: 16px !important;
    box-shadow: none;
  }

  .custom-section-content--image-inner-frame .image-block::after {
    content: '';
    position: absolute;
    inset: 16px;
    border: 1px solid var(--image-inner-frame-color, #FFFFFF);
    border-radius: 16px;
    pointer-events: none;
    z-index: 2;
  }

  .custom-section-content--image-border-outside .image-block {
    padding: 8px;
  }

  .custom-section-content--image-border-outside .image-block::after {
    inset: 0;
  }

  .custom-section__intro {
    --padding-block-start: 0;
    --padding-block-end: var(--padding-lg);
    --padding-inline-start: 0;
    --padding-inline-end: 0;

    max-width: 46rem;
    margin-inline: auto;
    text-align: center;
  }

  .custom-section__intro-heading {
    margin: 0;
  }

  .custom-section__intro-description {
    margin-block-start: var(--padding-sm);
  }

  .custom-section__intro-description p {
    margin: 0;
  }

  .section-wrapper .custom-section-content :is(ul, ol) {
    list-style: none;
    padding-inline-start: 0;
  }

  .section-wrapper .custom-section-content li {
    position: relative;
    padding-inline-start: 2.75rem;
    min-height: 34px;
    margin: 0.5rem 0;
  }

  .section-wrapper .custom-section-content li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 34px;
    height: 34px;
    transform: translateY(-50%);
    background-repeat: no-repeat;
    background-size: 34px 34px;
    background-image: url("data:image/svg+xml,%3Csvg width='34' height='34' viewBox='0 0 34 34' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Crect width='34' height='34' rx='17' fill='%23F9D8AF'/%3E%3Cpath d='M11.5918 16.2274L15.4554 20.091L22.41 13.9092' stroke='%2331331D' stroke-width='0.772727'/%3E%3C/svg%3E");
  }

  @media screen and (max-width: 749px) {
    .section-wrapper .section-content-wrapper {
      gap: calc(var(--gap) / 2);
    }
  }
{% endstylesheet %}
