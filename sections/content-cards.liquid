{% liquid
  assign section_width_class = 'section--' | append: section.settings.section_width
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="content-cards section spacing-style {{ section_width_class }} color-{{ section.settings.color_scheme }}"
  style="{% render 'spacing-padding', settings: section.settings %}"
>
  <div class="content-cards__header">
    {% if section.settings.heading != blank %}
      <h2 class="content-cards__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="content-cards__description rte">
        {{ section.settings.description }}
      </div>
    {% endif %}
  </div>

  <div class="content-cards__grid">
    {% for block in section.blocks %}
      {% assign block_settings = block.settings %}
      <article
        class="content-cards__card"
        {{ block.shopify_attributes }}
      >
        {% if block_settings.show_number and block_settings.number != blank %}
          <div class="content-cards__number">
            {{ block_settings.number }}
          </div>
        {% endif %}

        {% if block_settings.show_icon and block_settings.icon != blank %}
          <div class="content-cards__icon-wrap">
            {{
              block_settings.icon
              | image_url: width: 56
              | image_tag:
                class: 'content-cards__icon',
                widths: '28, 56',
                sizes: '28px',
                loading: 'lazy',
                alt: block_settings.icon.alt | default: block_settings.number | default: 'Card icon'
            }}
          </div>
        {% endif %}

        {% if block_settings.show_text and block_settings.text != blank %}
          <div class="content-cards__text rte">
            {{ block_settings.text }}
          </div>
        {% endif %}
      </article>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .content-cards {
    --content-cards-gap: 0.75rem;
    --content-cards-corner-radius: 10px;
    --content-cards-color-a: rgb(249 216 175 / 30%);
    --content-cards-color-b: rgb(219 217 211 / 30%);
  }

  .content-cards__header {
    max-width: 46rem;
    margin-inline: auto;
    text-align: center;
    margin-block-end: clamp(1.5rem, 4vw, 2.75rem);
  }

  .content-cards__heading {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .content-cards__description {
    margin-block-start: 0.85rem;
  }

  .content-cards__description p {
    margin: 0;
  }

  .content-cards__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--content-cards-gap);
  }

  .content-cards__card {
    border-radius: var(--content-cards-corner-radius);
    background: var(--content-cards-color-a);
    padding: clamp(1rem, 2vw, 1.25rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    min-height: 100%;
  }

  .content-cards__card:nth-child(even) {
    background: var(--content-cards-color-b);
  }

  .content-cards__number {
    width: 100%;
    text-align: start;
    margin-block-end: 0.6rem;
    font-family: var(--font-subheading--family);
  }

  .content-cards__icon-wrap {
    width: 28px;
    height: 28px;
    margin-block: 0.25rem 0.9rem;
  }

  .content-cards__icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
    display: block;
  }

  .content-cards__text p {
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .content-cards__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .content-cards__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Content cards",
  "tag": "section",
  "class": "section-content-cards",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HARVESTING THE POWER OF NATURE"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>All ingredients are 100% natural, organically grown or sourced from the Cala Falcó estate.</p>"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_number",
          "label": "Show number",
          "default": true
        },
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01."
        },
        {
          "type": "checkbox",
          "id": "show_icon",
          "label": "Show icon",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (SVG recommended)"
        },
        {
          "type": "checkbox",
          "id": "show_text",
          "label": "Show text",
          "default": true
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add a short card description here.</p>"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Content cards",
      "category": "Storytelling",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "number": "01.",
            "text": "<p>Cala Falcó produces limited batches using hand picked wild botanicals.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "number": "02.",
            "text": "<p>Steam-distilled hydrosols and cold-pressed oils shape the aromatic profile.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "number": "03.",
            "text": "<p>Mineral-rich sea salt is filtered and blended for balanced depth.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "number": "04.",
            "text": "<p>A vibrant hue from mastic berries crowns the blend with stability.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
