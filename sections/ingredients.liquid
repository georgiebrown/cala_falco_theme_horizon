{% liquid
  assign slide_count = section.blocks.size
  assign section_width_class = 'section--' | append: section.settings.section_width
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="ingredients section spacing-style {{ section_width_class }} color-{{ section.settings.color_scheme }}"
  style="
    {% render 'spacing-padding', settings: section.settings %};
    --ingredients-arrow-size: {{ section.settings.arrow_size }}px;
  "
>
  <div class="ingredients__header">
    {% if section.settings.heading != blank %}
      <h2 class="ingredients__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.description != blank %}
      <div class="ingredients__description rte">{{ section.settings.description }}</div>
    {% endif %}
  </div>

  <ingredients-swiper
    class="ingredients__swiper"
    data-slide-count="{{ slide_count }}"
    {% if request.design_mode %}
      data-design-mode="true"
    {% endif %}
  >
    <button
      class="ingredients__arrow ingredients__arrow--prev button button-unstyled button-unstyled--transparent"
      type="button"
      data-prev
      aria-label="{{ 'accessibility.slideshow_previous' | t }}"
    >
      <span class="svg-wrapper icon-arrow flip-x">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
    </button>

    <div class="ingredients__viewport">
      <div class="ingredients__track" data-track>
        {% for block in section.blocks %}
          {% liquid
            assign next_index = forloop.index0 | plus: 1
            if next_index >= slide_count
              assign next_index = 0
            endif
            assign next_block = section.blocks[next_index]
            assign current_image_alt = block.settings.image.alt | default: block.settings.title | default: 'Ingredient image'
            assign next_image_alt = next_block.settings.image.alt | default: next_block.settings.title | default: 'Next ingredient image'
          %}
          <article
            class="ingredients__slide"
            data-slide
            data-index="{{ forloop.index0 }}"
            aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="ingredients__content">
              <div class="ingredients__text">
                {% if block.settings.title != blank %}
                  <h3 class="ingredients__title">{{ block.settings.title }}</h3>
                {% endif %}
                {% if block.settings.description != blank %}
                  <div class="ingredients__copy rte">{{ block.settings.description }}</div>
                {% endif %}
              </div>

              <div class="ingredients__image-wrap">
                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 1200
                    | image_tag:
                      class: 'ingredients__image',
                      widths: '360, 560, 760, 960, 1200',
                      sizes: '(min-width: 990px) 28vw, 45vw',
                      loading: 'lazy',
                      alt: current_image_alt
                  }}
                {% endif %}
              </div>

              <div class="ingredients__next-image-wrap" aria-hidden="true">
                {% if next_block.settings.image != blank %}
                  {{
                    next_block.settings.image
                    | image_url: width: 1200
                    | image_tag:
                      class: 'ingredients__next-image',
                      widths: '360, 560, 760, 960, 1200',
                      sizes: '(min-width: 990px) 24vw, 0px',
                      loading: 'lazy',
                      alt: next_image_alt
                  }}
                {% endif %}
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>

    <button
      class="ingredients__arrow ingredients__arrow--next button button-unstyled button-unstyled--transparent"
      type="button"
      data-next
      aria-label="{{ 'accessibility.slideshow_next' | t }}"
    >
      <span class="svg-wrapper icon-arrow">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
    </button>
  </ingredients-swiper>
</section>

{% javascript %}
  class IngredientsSwiper extends HTMLElement {
    connectedCallback() {
      this.track = this.querySelector('[data-track]');
      this.prevButton = this.querySelector('[data-prev]');
      this.nextButton = this.querySelector('[data-next]');
      this.slides = Array.from(this.querySelectorAll('[data-slide]'));
      this.slideCount = Number(this.dataset.slideCount || this.slides.length);
      this.currentIndex = 0;

      if (!this.track || this.slideCount <= 1) {
        this.#setNavDisabled(true);
        return;
      }

      this.#bindEvents();
      this.#render(false);
    }

    disconnectedCallback() {
      if (this.handleResize) {
        window.removeEventListener('resize', this.handleResize);
      }
      if (this.blockSelectHandler) {
        document.removeEventListener('shopify:block:select', this.blockSelectHandler);
      }
    }

    #bindEvents() {
      if (this.prevButton) {
        this.prevButton.addEventListener('click', () => {
          this.#goTo(this.currentIndex - 1);
        });
      }

      if (this.nextButton) {
        this.nextButton.addEventListener('click', () => {
          this.#goTo(this.currentIndex + 1);
        });
      }

      this.handleResize = () => {
        this.#render(false);
      };
      window.addEventListener('resize', this.handleResize);

      this.blockSelectHandler = (event) => {
        if (!(event.target instanceof HTMLElement)) return;
        if (!this.contains(event.target)) return;

        const selectedSlide = event.target.closest('[data-slide]');
        if (!(selectedSlide instanceof HTMLElement)) return;

        const selectedIndex = Number(selectedSlide.dataset.index || 0);
        this.#goTo(selectedIndex, false);
      };
      document.addEventListener('shopify:block:select', this.blockSelectHandler);
    }

    #setNavDisabled(disabled) {
      if (this.prevButton instanceof HTMLButtonElement) {
        this.prevButton.disabled = disabled;
      }
      if (this.nextButton instanceof HTMLButtonElement) {
        this.nextButton.disabled = disabled;
      }
    }

    #goTo(index, animate = true) {
      const maxIndex = this.slideCount - 1;
      if (index < 0) {
        this.currentIndex = maxIndex;
      } else if (index > maxIndex) {
        this.currentIndex = 0;
      } else {
        this.currentIndex = index;
      }

      this.#render(animate);
    }

    #render(animate = true) {
      this.track.style.transitionDuration = animate ? '420ms' : '0ms';
      this.track.style.transform = `translate3d(-${this.currentIndex * 100}%, 0, 0)`;

      for (const [index, slide] of this.slides.entries()) {
        slide.setAttribute('aria-hidden', index === this.currentIndex ? 'false' : 'true');
      }
    }
  }

  if (!customElements.get('ingredients-swiper')) {
    customElements.define('ingredients-swiper', IngredientsSwiper);
  }
{% endjavascript %}

{% stylesheet %}
  .ingredients {
    --ingredients-content-max-width: 1200px;
  }

  .ingredients__header {
    margin-inline: auto;
    max-width: 52rem;
    text-align: center;
    margin-block-end: clamp(2rem, 6vw, 4rem);
  }

  .ingredients__heading {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .ingredients__description {
    margin-block-start: 0.9rem;
    margin-inline: auto;
    max-width: 36rem;
  }

  .ingredients__description p {
    margin: 0;
  }

  .ingredients__swiper {
    margin-inline: auto;
    max-width: var(--ingredients-content-max-width);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--padding-lg);
  }

  .ingredients__viewport {
    overflow: hidden;
    min-width: 0;
  }

  .ingredients__track {
    display: flex;
    transition: transform 420ms ease;
    will-change: transform;
  }

  .ingredients__slide {
    flex: 0 0 100%;
    min-width: 100%;
  }

  .ingredients__content {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(260px, 1.2fr) minmax(220px, 0.9fr);
    gap: clamp(1rem, 2.5vw, 2rem);
    align-items: center;
  }

  .ingredients__text {
    max-width: 22rem;
  }

  .ingredients__title {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ingredients__copy {
    margin-block-start: 1rem;
  }

  .ingredients__copy p {
    margin-block: 0;
  }

  .ingredients__image-wrap,
  .ingredients__next-image-wrap {
    width: 100%;
  }

  .ingredients__image,
  .ingredients__next-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .ingredients__next-image {
    opacity: 0.2;
  }

  .ingredients__arrow {
    width: var(--ingredients-arrow-size);
    height: var(--ingredients-arrow-size);
    border-radius: 999px;
    display: grid;
    place-items: center;
    background: rgb(var(--color-foreground-rgb) / 0.06);
    color: rgb(var(--color-foreground-rgb));
  }

  .ingredients__arrow:focus-visible {
    outline: 2px solid rgb(var(--color-foreground-rgb));
    outline-offset: 3px;
  }

  .ingredients__arrow[disabled] {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .ingredients__arrow .svg-wrapper {
    width: 0.95rem;
    height: 0.95rem;
  }

  @media screen and (max-width: 989px) {
    .ingredients__swiper {
      grid-template-columns: auto 1fr auto;
      gap: var(--padding-sm);
    }

    .ingredients__content {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .ingredients__text {
      margin-inline: auto;
    }

    .ingredients__next-image-wrap {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Ingredients",
  "tag": "section",
  "class": "section-ingredients",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nature's notes - the botanicals within"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>All ingredients are 100% natural and sourced with care.</p>"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page"
        },
        {
          "value": "full-width",
          "label": "Full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "arrow_size",
      "label": "Arrow size",
      "min": 36,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 52
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Honey"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>A natural antibacterial and antioxidant. Supports digestion and overall wellbeing.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Ingredients",
      "category": "Storytelling",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "title": "Honey",
            "description": "<p>A natural antibacterial and antioxidant. Acts as a dietary supplement for cardiovascular and immune health.</p>"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "Lemon",
            "description": "<p>Bright citrus notes that add freshness and a clean, aromatic lift to the blend.</p>"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "title": "Botanicals",
            "description": "<p>Carefully selected herbs and botanicals deliver depth, complexity, and structure.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
