<script
  src="{{ 'blog-posts-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<blog-posts-list section-id="{{ section.id }}">
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div
    class="
      section
      color-{{ section.settings.color_scheme }}
      blog-posts
      spacing-style
      size-style
    "
    data-testid="blog-posts"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    {% content_for 'blocks' %}

    {% if blog.all_tags.size > 0 %}
      <nav class="blog-posts__filters" aria-label="Filter blog posts by tag">
        <a
          href="{{ blog.url }}"
          class="blog-posts__filter-link{% if current_tags == blank %} is-active{% endif %}"
        >
          All
        </a>
        {% for tag in blog.all_tags %}
          <a
            href="{{ blog.url }}/tagged/{{ tag | handle }}"
            class="blog-posts__filter-link{% if current_tags contains tag %} is-active{% endif %}"
          >
            {{ tag }}
          </a>
        {% endfor %}
      </nav>
    {% endif %}

    <div
      ref="grid"
      class="blog-posts-container"
    >
      {% for article in blog.articles %}
        {% liquid
          assign col_span = 6
          assign scale = 1
          assign card_variant = 'list'

          if forloop.index == 1
            assign card_variant = 'hero'
          elsif forloop.index <= 3
            assign col_span = 3
            assign scale = 0.8
            assign card_variant = 'grid'
          endif
        %}
        {% style %}
          [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
            --col-span: {{ col_span }};
            --blog-post-card-scale: {{ scale }};
          }

          @media screen and (max-width: 749px) {
            [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
              --col-span: 6;
              --blog-post-card-scale: 0.5;
            }
          }
        {% endstyle %}
        <div
          class="blog-post-item blog-post-item--{{ card_variant }}"
          data-testid="blog-post-item"
          data-blog-index="{{ section.id }}-{{ forloop.index }}"
        >
          {% content_for 'block', id: 'static-blog-post-card', type: '_blog-post-card', article: article %}
        </div>
      {% endfor %}
    </div>
  </div>
</blog-posts-list>

{% stylesheet %}
  /**
   * Blog posts page layout
   */
  .blog-posts {
    --page-content-width: var(--narrow-page-width);
    --page-width: calc(var(--page-content-width) + (var(--page-margin) * 2));
    --columns-gap: 36px;
    --rows-gap: 36px;
  }

  .blog-posts__filters {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.25rem;
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 10%);
    margin-bottom: clamp(1.25rem, 3vw, 2.25rem);
    padding-bottom: 0.35rem;
  }

  .blog-posts__filter-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.1rem 0.7rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 20px;
    transition: color 180ms ease;
    font-family: var(--font-h4--family);
  }

  .blog-posts__filter-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.35rem;
    height: 7px;
    background: #d3a188;
    opacity: 0;
    transform: scaleX(0.6);
    transform-origin: center;
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .blog-posts__filter-link:hover,
  .blog-posts__filter-link.is-active {
    color: rgb(var(--color-foreground-rgb) / 100%);
  }

  .blog-posts__filter-link:hover::after,
  .blog-posts__filter-link.is-active::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .blog-posts-container {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
    width: 100%;
    column-gap: var(--columns-gap);
    row-gap: var(--rows-gap);
  }

  /**
   * Blog post item grid positioning and scaling.
   * Layout is calculated in Liquid based on total article count.
   * Mobile overrides are applied per-item in inline styles for proper specificity.
   */
  .blog-post-item {
    grid-column: span var(--col-span);
  }

  /**
   * When there's no image, the blog post item has a border.
   */
  .blog-post-item {
    border: 1px solid rgb(var(--color-foreground-rgb) / var(--opacity-20));
    padding: 0 1rem 1rem;
  }

  .blog-post-item:has(.blog-post-card__image-container) {
    border: none;
    padding: 0;
  }

  .blog-post-item--hero .blog-post-card {
    position: relative;
  }

  .blog-post-item--hero .blog-post-card__image-container::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(90deg, rgb(0 0 0 / 62%) 0%, rgb(0 0 0 / 18%) 40%, rgb(0 0 0 / 8%) 100%);
    border-radius: 16px;
  }

  .blog-post-item--hero .blog-post-card__content {
    position: absolute;
    left: clamp(1rem, 4vw, 2.5rem);
    bottom: clamp(1rem, 4vw, 2.25rem);
    z-index: 1;
    max-width: min(35rem, 65%);
    color: #fff;
    padding: 0;
  }

  .blog-post-item--hero .blog-post-card__content a,
  .blog-post-item--hero .blog-post-card__content .blog-post-card__content-text,
  .blog-post-item--hero .blog-post-card__content .blog-post-card__content-text a {
    color: inherit;
  }

  .blog-post-item--hero .blog-post-details {
    display: none;
  }

  .blog-post-item--hero .blog-post-card__content-text {
    margin-top: 0.3rem;
  }

  .blog-post-item--list {
    border: 0;
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 15%);
    padding: 0;
  }

  .blog-post-item--list:last-child {
    border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 15%);
  }

  .blog-post-item--list .blog-post-card {
    display: grid;
    grid-template-columns: minmax(8.5rem, 130px) minmax(0, 0.95fr) minmax(0, 1.15fr);
    align-items: center;
    column-gap: clamp(0.9rem, 2.2vw, 1.8rem);
    padding: clamp(0.8rem, 2vw, 1.2rem) 0;
    border-top: 1px solid lightgray;
  }

  .blog-post-item--list .blog-post-card__image {
    height: clamp(5rem, 7vw, 6.2rem);
  }

  .blog-post-item--list .blog-post-card__content {
    display: contents;
    padding: 0;
  }

  .blog-post-item--list .blog-post-card__content > a {
    grid-column: 2;
    padding: 0;
  }

  .blog-post-item--list .blog-post-details {
    display: none;
  }

  .blog-post-item--list .blog-post-card__content-text {
    grid-column: 3;
    margin: 0;
    padding: 0;
  }

  .blog-post-item--list .blog-post-card__content-text a {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .blog-posts__filters {
      gap: 0.8rem 1rem;
    }

    .blog-posts__filter-link {
      font-size: 0.72rem;
      letter-spacing: 0.06em;
    }

    .blog-post-item {
      border: 0;
      padding: 0;
    }

    .blog-post-item .blog-post-card {
      display: flex;
      flex-direction: column;
      padding: 0;
      row-gap: 0;
    }

    .blog-post-item .blog-post-card__content {
      display: flex;
      flex-direction: column;
      padding-top: 0.4rem;
    }

    .blog-post-item .blog-post-details {
      display: flex;
    }

    .blog-post-item--hero .blog-post-card__image-container::after {
      display: none;
    }

    .blog-post-item--hero .blog-post-card__content {
      position: static;
      left: auto;
      right: auto;
      bottom: auto;
      z-index: auto;
      max-width: 100%;
      color: inherit;
      padding: 0.4rem 0 0;
    }

    .blog-post-item--hero .blog-post-details {
      display: flex;
    }

    .blog-post-item--list .blog-post-card {
      display: flex;
      flex-direction: column;
      align-items: initial;
      column-gap: 0;
      padding: 0;
    }

    .blog-post-item--list .blog-post-card__content {
      display: flex;
      flex-direction: column;
      padding-top: 0.4rem;
    }

    .blog-post-item--list .blog-post-card__content > a,
    .blog-post-item--list .blog-post-card__content-text {
      grid-column: auto;
      margin: 0;
      padding: 0;
    }

    .blog-post-item--list .blog-post-card__content-text a {
      display: inline;
    }

    .blog-post-item--list .blog-post-card__image {
      height: calc(var(--blog-post-card-img-height) * var(--blog-post-card-scale));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_posts",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "text"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "button"
    },
    {
      "type": "video"
    },
    {
      "type": "group"
    },
    {
      "type": "spacer"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
