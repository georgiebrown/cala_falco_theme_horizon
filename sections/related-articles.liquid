{% liquid
  assign related_article = article.next_article

  if related_article == blank
    assign related_article = article.previous_article
  endif

  # Fallback for contexts where next/previous are not populated
  if related_article == blank
    assign previous_in_blog = blank
    assign next_in_blog = blank
    assign found_current_article = false

    for blog_article in blog.articles
      if found_current_article and next_in_blog == blank
        assign next_in_blog = blog_article
      endif

      if blog_article.id == article.id
        assign found_current_article = true
      else
        assign previous_in_blog = blog_article
      endif
    endfor

    if next_in_blog != blank
      assign related_article = next_in_blog
    elsif previous_in_blog != blank
      assign related_article = previous_in_blog
    endif
  endif

  assign has_related_article = false
  if related_article != blank
    assign has_related_article = true
  endif
%}

{% if has_related_article %}
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <section
    class="section section--page-width related-articles color-{{ section.settings.color_scheme }} spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
    data-testid="related-articles"
  >
    <div class="related-articles__inner">
      {% if section.settings.heading != blank %}
        <h2 class="related-articles__heading h5">{{ section.settings.heading }}</h2>
      {% endif %}

      <a class="related-articles__card" href="{{ related_article.url }}">
        {% if related_article.image != blank %}
          <div class="related-articles__media">
            {{
              related_article.image
              | image_url: width: 600
              | image_tag:
                widths: '240, 360, 480, 600',
                sizes: '(max-width: 749px) 100vw, 240px',
                class: 'related-articles__image',
                alt: related_article.image.alt
            }}
          </div>
        {% endif %}

        <div class="related-articles__content">
          <p class="related-articles__title">{{ related_article.title }}</p>
          <span class=" button">
            {{- section.settings.button_label -}}
           
          </span>
        </div>
      </a>
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .related-articles__inner {
    width: min(100%, 760px);
    margin: 0 auto;
  }

  .related-articles__heading {
    margin: 0 0 var(--padding-md);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .related-articles__card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--padding-md);
    text-decoration: none;
    color: var(--color-foreground);
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .related-articles__card {
      grid-template-columns: 240px 1fr;
      gap: var(--gap-lg);
    }
  }

  .related-articles__media {
    overflow: hidden;
  }

  .related-articles__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 9;
    display: block;
    border-radius: 16px;
    border: 1px solid  rgb(var(--color-foreground-rgb) / var(--opacity-10-25));;
    padding: 0.5rem;
  }

  .related-articles__content {
    display: grid;
    gap: var(--padding-sm);
    align-content: start;
  }

  .related-articles__title {
    margin: 0;
    text-underline-offset: 0.2em;
    text-transform: uppercase;
    letter-spacing: 0.04em;
        font-family: var(--font-h2--family);
  }

  .related-articles__button {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: var(--padding-2xs) var(--padding-md);
    border-radius: 999px;
    background: rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    color: var(--color-foreground);
    font-size: var(--font-size--body-sm);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Related articles",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Related Articles"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Next Article"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": []
}
{% endschema %}
