<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {% liquid
    assign total_blocks = section.blocks.size
    assign footer_link_source = section.settings.footer_link_source | default: 'policies'
    assign has_footer_links = false

    if footer_link_source == 'menu' and section.settings.footer_links_menu != blank
      assign has_footer_links = true
    elsif footer_link_source == 'policies' and shop.policies.size > 0
      assign has_footer_links = true
    endif

    # Grid layout calculations
    assign grid_columns = total_blocks | at_most: 4

    # Calculate last row counts using modulo arithmetic
    # last_row_count = (total_blocks - 1) % N + 1
    assign last_row_count = total_blocks | minus: 1 | modulo: 4 | plus: 1
    assign tablet_last_row_count = total_blocks | minus: 1 | modulo: 2 | plus: 1

    # Check if there are orphaned elements (single item in last row)
    assign has_isolated_grid_item_desktop = false
    assign has_isolated_grid_item_tablet = false

    if total_blocks > 4 and last_row_count == 1
      assign has_isolated_grid_item_desktop = true
    endif

    if total_blocks == 5
      assign has_isolated_grid_item_tablet = true
    endif
  %}
  <div class="footer-shell">
    {% if section.settings.footer_logo != blank %}
      <div class="footer-shell__floating-logo">
        {{
          section.settings.footer_logo
          | image_url: width: 640
          | image_tag:
            widths: '120, 180, 240, 320, 480, 640',
            class: 'footer-shell__floating-logo-image',
            loading: 'lazy',
            alt: section.settings.footer_logo.alt | default: shop.name
        }}
      </div>
    {% endif %}
    <div class="footer-shell__frame">
      <div
        class="
          footer-content
          spacing-style
          {% if has_isolated_grid_item_desktop %}footer-content--isolated-grid-item-desktop{% endif %}
          {% if has_isolated_grid_item_tablet %}footer-content--isolated-grid-item-tablet{% endif %}
        "
        style="
          {%  render 'spacing-style', settings: section.settings %}
          --footer-gap: {{ section.settings.gap }}px;
          --grid-columns: {{ grid_columns }};
          --last-row-count: {{ last_row_count }};
          --tablet-last-row-count: {{ tablet_last_row_count }};
        "
      >
        {% content_for 'blocks' %}
      </div>
      {% if has_footer_links %}
        <div class="footer-shell__policy-links-wrap">
          <ul
            class="footer-shell__policy-links list-unstyled"
            style="
              --font-size: {{ section.settings.footer_links_font_size }};
              --text-transform: {{ section.settings.footer_links_case }};
            "
          >
            {% if footer_link_source == 'menu' and section.settings.footer_links_menu != blank %}
              {% for link in section.settings.footer_links_menu.links %}
                {% if link != blank %}
                  <li>
                    <a href="{{ link.url }}">{{ link.title | escape }}</a>
                  </li>
                {% endif %}
              {% endfor %}
            {% else %}
              {% for policy in shop.policies %}
                {% if policy != blank %}
                  <li>
                    <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
                  </li>
                {% endif %}
              {% endfor %}
            {% endif %}
          </ul>
          <div
            class="footer-shell__copyright"
            style="
              --font-size: {{ section.settings.footer_copyright_font_size }};
              --text-transform: {{ section.settings.footer_copyright_case }};
            "
          >
            <span class="footer-utilities__text">
              &copy; {{ 'now' | date: '%Y' }}
              {{ shop.name | link_to: routes.root_url -}}. All rights reserved.
              {%- if section.settings.footer_show_powered_by -%}
                , {{ powered_by_link }}
              {%- endif -%}
            </span>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .footer-content {
    contain: content;
    content-visibility: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--footer-gap);
  }

  .footer-shell {
    position: relative;
    padding-block-start: 5rem;
    padding-block-end: 2rem;
  }

  .footer-shell__frame {
    border: 1px solid #F4C077;
    border-radius: 1.2rem;
    padding: clamp(1.5rem,3vw,2.5rem) clamp(2rem,7vw,8rem)!important}

  .footer-shell__policy-links-wrap {
    margin-top: clamp(1.2rem, 2.2vw, 2rem);
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .footer-shell__policy-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin: 0;
    padding: 0;
  }

  .footer-shell__policy-links li {
    margin: 0;
    padding: 0;
  }

  .footer-shell__policy-links a {
    color: inherit;
    text-decoration: none;
    font-size: var(--font-size, 0.75rem);
    text-transform: var(--text-transform, none);
  }

  .footer-shell__policy-links a:hover {
    text-decoration: underline;
  }

  .footer-shell__copyright {
    font-size: var(--font-size, 0.75rem);
    text-transform: var(--text-transform, none);
  }

  .footer-shell__copyright a {
    color: inherit;
  }

  .footer-shell__floating-logo {
    position: absolute;
    top: 15%;
    left:7%;
    transform: translateY(-45%);
    z-index: 2;
    pointer-events: none;
    width: 100px;
  }

  .footer-shell__floating-logo-image {
    width: min(180px, 24vw);
    height: auto;
    display: block;
  }

  .footer-content > .logo-block {
    display: none;
  }

  .footer-content > .email-signup-block {
    grid-column: 1;
  }

  .footer-content .email-signup__input-group {
    position: relative;
    align-items: center;
    border: 1px solid #686868;
    border-radius: 100px;
    background: transparent;
    min-height: 3.25rem;
    gap: 0;
  }

  .footer-content .email-signup__input-group .email-signup__input {
    border: none;
    border-radius: 0;
    background: transparent;
    min-height: 3.25rem;
    padding-inline-end: 10.5rem;
  }

  .footer-content .email-signup__input-group .email-signup__button {
    position: absolute;
    right: 0;
    top: 0;
    transform: none;
    margin: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: auto;
    min-width: 7.75rem;
    height: 100%;
    border-radius: 999px;
  }

  .footer-content .email-signup__button.email-signup__button--text {
    padding-inline: 1.75rem;
  }

  .footer-content .email-signup__button.email-signup__button--text::after {
    content: '';
    width: 12px;
    height: 8px;
    display: inline-block;
    background-repeat: no-repeat;
    background-size: 12px 8px;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M11.3536 4.03568C11.5488 3.84042 11.5488 3.52384 11.3536 3.32858L8.17157 0.146595C7.97631 -0.0486672 7.65973 -0.0486672 7.46447 0.146595C7.2692 0.341857 7.2692 0.65844 7.46447 0.853702L10.2929 3.68213L7.46447 6.51056C7.2692 6.70582 7.2692 7.0224 7.46447 7.21766C7.65973 7.41293 7.97631 7.41293 8.17157 7.21766L11.3536 4.03568ZM0 3.68213V4.18213H11V3.68213V3.18213H0V3.68213Z' fill='%2331331D'/%3E%3C/svg%3E");
  }

  .footer-content > .menu::before {
    content: 'Quick Links';
    display: block;
    margin-block-end: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.75rem;
  }

  .footer-content > .social-icons__wrapper {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .footer-content > .social-icons__wrapper::before {
    content: 'Follow us';
    display: inline-block;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.75rem;
    white-space: nowrap;
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .footer-content {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-flow: row;
      align-items: start;
      row-gap: var(--footer-gap);
      column-gap: calc(var(--footer-gap) * 2);
    }

    .footer-content--isolated-grid-item-tablet > :last-child {
      grid-column: 1 / -1;
    }

    .footer-content > .group-block {
      grid-column: 1;
      grid-row: 1;
    }

    .footer-content > .email-signup-block {
      grid-column: 1;
      grid-row: 2;
    }

    .footer-content > .footer-utilities__group-copyright {
      grid-column: 1;
      grid-row: 3;
    }

    .footer-content > .menu {
      grid-column: 2;
      grid-row: 1;
      justify-self: start;
    }

    .footer-content > .social-icons__wrapper {
      grid-column: 2;
      grid-row: 2;
      justify-self: start;
    }
  }

  @media screen and (max-width: 750px) {
    .footer-shell__floating-logo{
    top: 8%
    }
  }


  @media screen and (min-width: 990px) {
    .footer-content {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
      row-gap: var(--footer-gap);
      column-gap: calc(var(--footer-gap) * 2);
    }

    /* Single item centered */
    .footer-content[style*='--grid-columns: 1'] {
      justify-items: center;
    }

    .footer-content--isolated-grid-item-desktop > :last-child {
      grid-column: 1 / -1;
    }

    .footer-content > .group-block {
      grid-column: 1;
      grid-row: 1;
    }

    .footer-content > .email-signup-block {
      grid-column: 1;
      grid-row: 2;
    }

    .footer-content > .footer-utilities__group-copyright {
      grid-column: 1;
      grid-row: 3;
    }

    .footer-content > .menu {
      grid-column: 2;
      grid-row: 1;
      justify-self: start;
    }

    .footer-content > .social-icons__wrapper {
      grid-column: 2;
      grid-row: 2;
      justify-self: start;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "_divider"
    },
    {
      "type": "@app"
    },
    {
      "type": "button"
    },
    {
      "type": "follow-on-shop"
    },
    {
      "type": "group"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "menu"
    },
    {
      "type": "payment-icons"
    },
    {
      "type": "text"
    },
    {
      "type": "logo"
    },
    {
      "type": "jumbo-text"
    },
    {
      "type": "social-links"
    },
    {
      "type": "email-signup"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer border logo"
    },
    {
      "type": "header",
      "content": "Footer links"
    },
    {
      "type": "select",
      "id": "footer_link_source",
      "label": "Link source",
      "options": [
        {
          "value": "policies",
          "label": "Policies"
        },
        {
          "value": "menu",
          "label": "Menu"
        }
      ],
      "default": "policies"
    },
    {
      "type": "link_list",
      "id": "footer_links_menu",
      "label": "Menu",
      "visible_if": "{{ section.settings.footer_link_source == 'menu' }}"
    },
    {
      "type": "select",
      "id": "footer_links_font_size",
      "label": "Link size",
      "options": [
        {
          "value": "0.625rem",
          "label": "10px"
        },
        {
          "value": "0.75rem",
          "label": "12px"
        },
        {
          "value": "0.875rem",
          "label": "14px"
        },
        {
          "value": "1rem",
          "label": "16px"
        },
        {
          "value": "1.125rem",
          "label": "18px"
        }
      ],
      "default": "0.75rem"
    },
    {
      "type": "select",
      "id": "footer_links_case",
      "label": "Link case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Footer copyright"
    },
    {
      "type": "checkbox",
      "id": "footer_show_powered_by",
      "label": "Show powered by Shopify",
      "default": true
    },
    {
      "type": "select",
      "id": "footer_copyright_font_size",
      "label": "Copyright size",
      "options": [
        {
          "value": "0.625rem",
          "label": "10px"
        },
        {
          "value": "0.75rem",
          "label": "12px"
        },
        {
          "value": "0.875rem",
          "label": "14px"
        },
        {
          "value": "1rem",
          "label": "16px"
        },
        {
          "value": "1.125rem",
          "label": "18px"
        }
      ],
      "default": "0.75rem"
    },
    {
      "type": "select",
      "id": "footer_copyright_case",
      "label": "Copyright case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:names.footer",
      "category": "t:categories.footer",
      "settings": {
        "gap": 20,
        "color_scheme": "scheme-1",
        "padding-block-start": 36,
        "padding-block-end": 36
      },
      "blocks": {
        "newsletter-group": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "gap": 6,
            "width": "fill",
            "inherit_color_scheme": true
          },
          "blocks": {
            "newsletter-heading": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.join_our_email_list",
                "width": "100%",
                "alignment": "left",
                "type_preset": "h3"
              }
            },
            "newsletter-text": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.get_exclusive_deals_and_early_access_to_new_products",
                "width": "100%",
                "alignment": "left",
                "type_preset": "rte"
              }
            }
          },
          "block_order": ["newsletter-heading", "newsletter-text"]
        },
        "newsletter-form": {
          "type": "email-signup",
          "settings": {
            "width": "fill"
          }
        }
      },
      "block_order": ["newsletter-group", "newsletter-form"]
    }
  ]
}
{% endschema %}
