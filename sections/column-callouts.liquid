{% liquid
  assign has_background_image = false
  if section.settings.background_image != blank
    assign has_background_image = true
  endif
%}

<section
  class="column-callouts section section--full-width color-{{ section.settings.color_scheme }}"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --column-callouts-min-height: {{ section.settings.section_height }};
    --column-callouts-overlay-max-width: {{ section.settings.content_width | plus: 80 }}px;
  "
  data-testid="column-callouts"
>
  {% if has_background_image %}
    {{
      section.settings.background_image
      | image_url: width: 3840
      | image_tag:
        widths: '750, 1100, 1500, 2000, 2500, 3000, 3840',
        sizes: '100vw',
        class: 'column-callouts__background-image',
        alt: ''
    }}
  {% else %}
    <div class="column-callouts__background-placeholder" aria-hidden="true"></div>
  {% endif %}

  <div class="column-callouts__overlay">
    {% if section.settings.heading != blank %}
      <h2 class="column-callouts__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="column-callouts__grid" role="list">
      {% for block in section.blocks %}
        <article class="column-callouts__item" role="listitem" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            {{
              block.settings.icon
              | image_url: width: 64
              | image_tag:
                widths: '32, 48, 64',
                sizes: '32px',
                class: 'column-callouts__icon',
                alt: ''
            }}
          {% endif %}

          {% if block.settings.title != blank %}
            <h3 class="column-callouts__item-heading">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <div class="column-callouts__item-text rte">
              {{ block.settings.text }}
            </div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .column-callouts {
    position: relative;
    min-height: var(--column-callouts-min-height);
    display: grid;
    align-items: end;
    overflow: hidden;
    isolation: isolate;
  }

  .column-callouts__background-image,
  .column-callouts__background-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -1;
  }

  .column-callouts__background-placeholder {
    background: rgb(var(--color-background-rgb));
  }

  .column-callouts__overlay {
    width: min(calc(100% - (2 * var(--page-margin))), var(--column-callouts-overlay-max-width));
    margin-inline: auto;
    margin-bottom: var(--page-margin);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    background: rgb(var(--color-background-rgb) / 0.7);
    backdrop-filter: blur(2px);
    border: var(--style-border-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-10-25));
    border-radius: 24px;
  }

  .column-callouts__heading {
    margin: 0 0 var(--padding-md);
    text-align: center;
  }

  .column-callouts__grid {
    display: grid;
    grid-template-columns: repeat(var(--column-callouts-columns, 3), minmax(0, 1fr));
    gap: var(--gap-xl);
  }

  .column-callouts__item {
    text-align: center;
    display: grid;
    justify-items: center;
    gap: var(--padding-lg);
    padding-inline: clamp(1rem, 2vw, 1.75rem);
  }

  .column-callouts__item + .column-callouts__item {
    border-inline-start: 1px solid rgb(49 51 29 / 20%);
  }

  .column-callouts__icon {
    width: auto;
    height: 16px;
    object-fit: contain;
  }

  .column-callouts__item-heading {
    margin: 0;
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-weight: var(--font-heading--weight);
    font-size: var(--font-size--xl);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .column-callouts__item-text {
    margin: 0;
    max-width: 28ch;
  }

  .column-callouts__item-text p {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .column-callouts {
      min-height: auto;
    }

    .column-callouts__overlay {
      width: min(calc(100% - (2 * var(--page-margin))), 42rem);
      margin-bottom: var(--padding-lg);
      margin-top: var(--padding-lg);
      padding: var(--padding-lg);
      border-radius: 20px;
    }

    .column-callouts__grid {
      grid-template-columns: 1fr;
      gap: var(--padding-lg);
    }

    .column-callouts__item {
      padding-inline: 0;
    }

    .column-callouts__item + .column-callouts__item {
      border-inline-start: 0;
      border-top: 1px solid rgb(49 51 29 / 20%);
      padding-top: var(--padding-lg);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Column callouts",
  "tag": "section",
  "class": "section-column-callouts",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 640,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 980
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "options": [
        { "value": "500px", "label": "Small" },
        { "value": "620px", "label": "Medium" },
        { "value": "740px", "label": "Large" }
      ],
      "default": "620px"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "callout",
      "name": "Callout",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Callout heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add supporting callout text here.</p>"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Column callouts",
      "blocks": [
        {
          "type": "callout",
          "settings": {
            "title": "Natural",
            "text": "<p>We are committed to sourcing the most exceptional natural ingredients.</p>"
          }
        },
        {
          "type": "callout",
          "settings": {
            "title": "Artisanal",
            "text": "<p>Our perfumers blend essence by hand to create complex fragrances.</p>"
          }
        },
        {
          "type": "callout",
          "settings": {
            "title": "Sustainable",
            "text": "<p>From sourcing to packaging, every step favors environmental stewardship.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
